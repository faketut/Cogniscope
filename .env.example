# LLM provider: "gemini", "qwen", or "mock"
LLM_PROVIDER=mock

# Get a key at https://aistudio.google.com/
GEMINI_API_KEY=

# Get a DashScope key at https://dashscope.console.aliyun.com/
QWEN_API_KEY=
QWEN_MODEL=
WORKSPACE_ID=
QWEN_BASE_URL=https://${WORKSPACE_ID}.<region>.aliyuncs.com/compatible-mode/v1
